{
  "expo": {
    "name": "LeMondeRssReader",
    "slug": "LeMondeRssReader",
    "version": "4.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lemonderssreader",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "org.mbach.lemonde",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "lemonde.fr",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.lemonde.fr",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "versionCode": 42
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": null
        }
      ],
      "./plugins/withAdaptiveIconSplashScreen",
      "./plugins/withAndroidCustomAssets",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
